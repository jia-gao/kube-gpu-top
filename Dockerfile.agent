FROM golang:1.26-bookworm AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# go-nvml requires CGO; it uses dlopen at runtime to find libnvidia-ml.so,
# so the resulting binary does not need to link against CUDA at build time.
# The runtime stage is Ubuntu-based (glibc), so no static-linking gymnastics
# are needed.
RUN CGO_ENABLED=1 go build -ldflags="-s -w" -o /kube-gpu-agent ./cmd/kube-gpu-agent/

FROM nvidia/cuda:12.9.0-base-ubuntu24.04

COPY --from=builder /kube-gpu-agent /usr/local/bin/kube-gpu-agent

ENTRYPOINT ["kube-gpu-agent"]
